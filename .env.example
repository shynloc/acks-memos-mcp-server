# Memos instance URL
MEMOS_API_URL=https://your-memos-instance.com

# Personal Access Token from Memos -> Settings -> Members
MEMOS_ACCESS_TOKEN=your_memos_pat_here

# (Optional) Transport mode: "sse" for HTTP server, omit for stdio
# TRANSPORT=sse

# (Optional, SSE mode only) Port and host
# PORT=3000
# HOST=0.0.0.0
